{
	"$defs": {
		"CalorieMacroInput": {
			"description": "Calorie Macro Engine の入力。",
			"properties": {
				"age": {
					"description": "年齢 (成人のみ)。",
					"maximum": 120,
					"minimum": 18,
					"title": "Age",
					"type": "integer"
				},
				"sex": {
					"description": "生物学的性別 (BMR 計算に必要)。",
					"enum": ["male", "female"],
					"title": "Sex",
					"type": "string"
				},
				"height_cm": {
					"description": "身長 (cm)。",
					"exclusiveMaximum": 300,
					"exclusiveMinimum": 0,
					"title": "Height Cm",
					"type": "number"
				},
				"weight_kg": {
					"description": "現在体重 (kg)。",
					"exclusiveMaximum": 500,
					"exclusiveMinimum": 0,
					"title": "Weight Kg",
					"type": "number"
				},
				"activity_level": {
					"description": "PAL 活動係数を決める活動レベル。",
					"enum": [
						"sedentary",
						"lightly_active",
						"moderately_active",
						"very_active",
						"extremely_active"
					],
					"title": "Activity Level",
					"type": "string"
				},
				"sleep_hours": {
					"description": "平均睡眠時間 (caution 条件判定に使う)。",
					"maximum": 24,
					"minimum": 0,
					"title": "Sleep Hours",
					"type": "number"
				},
				"stress_level": {
					"description": "ストレスレベル (caution 条件判定に使う)。",
					"enum": ["low", "moderate", "high"],
					"title": "Stress Level",
					"type": "string"
				}
			},
			"required": [
				"age",
				"sex",
				"height_cm",
				"weight_kg",
				"activity_level",
				"sleep_hours",
				"stress_level"
			],
			"title": "CalorieMacroInput",
			"type": "object"
		},
		"HydrationInput": {
			"description": "Hydration Engine への入力。",
			"properties": {
				"weight_kg": {
					"description": "現在体重 (kg)。",
					"exclusiveMaximum": 500,
					"exclusiveMinimum": 0,
					"title": "Weight Kg",
					"type": "number"
				},
				"workouts_per_week": {
					"description": "週の運動頻度 (回)。",
					"maximum": 14,
					"minimum": 0,
					"title": "Workouts Per Week",
					"type": "integer"
				},
				"avg_workout_minutes": {
					"description": "1 回あたりの平均運動時間 (分)。",
					"maximum": 300,
					"minimum": 0,
					"title": "Avg Workout Minutes",
					"type": "integer"
				},
				"job_type": {
					"description": "仕事の身体負荷タイプ。",
					"enum": [
						"desk",
						"standing",
						"light_physical",
						"manual_labour",
						"outdoor"
					],
					"title": "Job Type",
					"type": "string"
				}
			},
			"required": [
				"weight_kg",
				"workouts_per_week",
				"avg_workout_minutes",
				"job_type"
			],
			"title": "HydrationInput",
			"type": "object"
		},
		"SupplementInput": {
			"description": "Supplement Recommender への入力。",
			"properties": {
				"protein_gap_g": {
					"description": "タンパク質目標と食事からの推定摂取量の差 (g)。正なら不足 (ホエイ推奨トリガー)、負なら過剰。",
					"title": "Protein Gap G",
					"type": "number"
				},
				"workouts_per_week": {
					"maximum": 14,
					"minimum": 0,
					"title": "Workouts Per Week",
					"type": "integer"
				},
				"sleep_hours": {
					"maximum": 24,
					"minimum": 0,
					"title": "Sleep Hours",
					"type": "number"
				},
				"fish_per_week": {
					"description": "週の魚摂取回数 (オメガ3 推奨トリガー)。",
					"maximum": 21,
					"minimum": 0,
					"title": "Fish Per Week",
					"type": "integer"
				},
				"early_morning_training": {
					"default": false,
					"description": "早朝トレーニング習慣または眠気対策のニーズ (カフェイン推奨トリガー)。",
					"title": "Early Morning Training",
					"type": "boolean"
				},
				"low_sunlight_exposure": {
					"default": false,
					"description": "日照不足・冬場・屋内労働中心 (ビタミン D 推奨トリガー)。",
					"title": "Low Sunlight Exposure",
					"type": "boolean"
				}
			},
			"required": [
				"protein_gap_g",
				"workouts_per_week",
				"sleep_hours",
				"fish_per_week"
			],
			"title": "SupplementInput",
			"type": "object"
		}
	},
	"properties": {
		"calorie_macro_input": {
			"$ref": "#/$defs/CalorieMacroInput"
		},
		"hydration_input": {
			"$ref": "#/$defs/HydrationInput"
		},
		"supplement_input": {
			"$ref": "#/$defs/SupplementInput"
		}
	},
	"required": ["calorie_macro_input", "hydration_input", "supplement_input"],
	"title": "SafeAgentInput",
	"type": "object"
}
