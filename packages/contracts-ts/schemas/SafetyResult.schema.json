{
	"description": "Safety Guard の出力。level ごとに必須フィールドと許容値が異なる Discriminated Union。",
	"oneOf": [
		{
			"type": "object",
			"description": "safe: 制限なくプラン生成可能。",
			"properties": {
				"level": { "const": "safe", "type": "string" },
				"allowed_to_generate_plan": { "const": true, "type": "boolean" },
				"response_mode": { "const": "normal", "type": "string" },
				"reasons": {
					"type": "array",
					"items": { "type": "string" }
				}
			},
			"required": ["level", "allowed_to_generate_plan", "response_mode"],
			"additionalProperties": false
		},
		{
			"type": "object",
			"description": "caution: 注意付きでプラン生成可能。reasons 必須。",
			"properties": {
				"level": { "const": "caution", "type": "string" },
				"allowed_to_generate_plan": { "type": "boolean" },
				"response_mode": {
					"enum": ["normal", "limited"],
					"type": "string"
				},
				"reasons": {
					"type": "array",
					"items": { "type": "string" },
					"minItems": 1
				}
			},
			"required": [
				"level",
				"allowed_to_generate_plan",
				"response_mode",
				"reasons"
			],
			"additionalProperties": false
		},
		{
			"type": "object",
			"description": "blocked: プラン生成不可。reasons 必須、allowed=false 固定。",
			"properties": {
				"level": { "const": "blocked", "type": "string" },
				"allowed_to_generate_plan": { "const": false, "type": "boolean" },
				"response_mode": {
					"enum": ["limited", "medical_redirect"],
					"type": "string"
				},
				"reasons": {
					"type": "array",
					"items": { "type": "string" },
					"minItems": 1
				}
			},
			"required": [
				"level",
				"allowed_to_generate_plan",
				"response_mode",
				"reasons"
			],
			"additionalProperties": false
		}
	],
	"title": "SafetyResult"
}
