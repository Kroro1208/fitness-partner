{
	"$defs": {
		"Meal": {
			"properties": {
				"slot": {
					"enum": ["breakfast", "lunch", "dinner", "dessert"],
					"title": "Slot",
					"type": "string"
				},
				"title": {
					"maxLength": 120,
					"minLength": 1,
					"title": "Title",
					"type": "string"
				},
				"items": {
					"items": {
						"$ref": "#/$defs/MealItem"
					},
					"maxItems": 10,
					"minItems": 1,
					"title": "Items",
					"type": "array"
				},
				"total_calories_kcal": {
					"maximum": 5000,
					"minimum": 0,
					"title": "Total Calories Kcal",
					"type": "integer"
				},
				"total_protein_g": {
					"maximum": 300,
					"minimum": 0,
					"title": "Total Protein G",
					"type": "number"
				},
				"total_fat_g": {
					"maximum": 300,
					"minimum": 0,
					"title": "Total Fat G",
					"type": "number"
				},
				"total_carbs_g": {
					"maximum": 600,
					"minimum": 0,
					"title": "Total Carbs G",
					"type": "number"
				},
				"prep_tag": {
					"anyOf": [
						{
							"enum": ["batch", "quick", "treat", "none"],
							"type": "string"
						},
						{
							"type": "null"
						}
					],
					"default": null,
					"title": "Prep Tag"
				},
				"notes": {
					"anyOf": [
						{
							"items": {
								"type": "string"
							},
							"type": "array"
						},
						{
							"type": "null"
						}
					],
					"default": null,
					"title": "Notes"
				}
			},
			"required": [
				"slot",
				"title",
				"items",
				"total_calories_kcal",
				"total_protein_g",
				"total_fat_g",
				"total_carbs_g"
			],
			"title": "Meal",
			"type": "object"
		},
		"MealItem": {
			"properties": {
				"food_id": {
					"anyOf": [
						{
							"type": "string"
						},
						{
							"type": "null"
						}
					],
					"default": null,
					"description": "FoodCatalog の food_id。LLM 創作は null。",
					"title": "Food Id"
				},
				"name": {
					"maxLength": 120,
					"minLength": 1,
					"title": "Name",
					"type": "string"
				},
				"grams": {
					"exclusiveMinimum": 0,
					"maximum": 2000,
					"title": "Grams",
					"type": "number"
				},
				"calories_kcal": {
					"maximum": 5000,
					"minimum": 0,
					"title": "Calories Kcal",
					"type": "integer"
				},
				"protein_g": {
					"maximum": 300,
					"minimum": 0,
					"title": "Protein G",
					"type": "number"
				},
				"fat_g": {
					"maximum": 300,
					"minimum": 0,
					"title": "Fat G",
					"type": "number"
				},
				"carbs_g": {
					"maximum": 600,
					"minimum": 0,
					"title": "Carbs G",
					"type": "number"
				}
			},
			"required": [
				"name",
				"grams",
				"calories_kcal",
				"protein_g",
				"fat_g",
				"carbs_g"
			],
			"title": "MealItem",
			"type": "object"
		}
	},
	"description": "candidates 生成結果。``proposal_id`` を client が apply で返す。",
	"properties": {
		"proposal_id": {
			"description": "uuid v4。",
			"title": "Proposal Id",
			"type": "string"
		},
		"proposal_expires_at": {
			"description": "ISO 8601 (生成時刻 + 10 分)。",
			"title": "Proposal Expires At",
			"type": "string"
		},
		"candidates": {
			"items": {
				"$ref": "#/$defs/Meal"
			},
			"maxItems": 3,
			"minItems": 3,
			"title": "Candidates",
			"type": "array"
		}
	},
	"required": ["proposal_id", "proposal_expires_at", "candidates"],
	"title": "MealSwapCandidatesResponse",
	"type": "object"
}
